# ── AI provider ──────────────────────────────────────────────────────
# Embeddings run locally (sentence-transformers all-MiniLM-L6-v2) — no extra key needed.
#
# Pick one chat-LLM provider. `anthropic` is the default; flip to
# `openai` to use OpenAI or any OpenAI-compatible endpoint (Azure
# OpenAI, Together AI, Groq, OpenRouter, Ollama, vLLM, LM Studio, ...).
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
CHAT_MODEL=claude-sonnet-4-6

# OpenAI / OpenAI-compatible (used when LLM_PROVIDER=openai)
#   OpenAI:           https://api.openai.com/v1
#   Azure OpenAI:     https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   Together AI:      https://api.together.xyz/v1
#   Groq:             https://api.groq.com/openai/v1
#   OpenRouter:       https://openrouter.ai/api/v1
#   DeepSeek:         https://api.deepseek.com/v1                 model: deepseek-chat
#   Moonshot / Kimi:  https://api.moonshot.cn/v1                  model: moonshot-v1-128k
#                     (international: https://api.moonshot.ai/v1)
#   MiniMax:          https://api.minimaxi.com/v1                 model: MiniMax-Text-01
#                     (legacy:        https://api.minimax.chat/v1 model: abab6.5s-chat)
#   Ollama (local):   http://host.docker.internal:11434/v1
#   vLLM/LM Studio:   http://host.docker.internal:8000/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

# Auth
AUTH_MODE=stub                        # 'stub' for dev, 'oidc' for production
JWT_SECRET=change-me-in-prod-please
OIDC_ISSUER=                          # e.g. https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Database
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki
POSTGRES_DB=wiki
